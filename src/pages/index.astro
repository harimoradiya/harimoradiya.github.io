---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: "TV Remote for Android TV",
    category: "Android App • Open Source",
    excerpt: "Control your Android TV or Google TV from your phone. 100% free, open source, no ads, no premium subscriptions.",
    techStack: "Kotlin, Compose, Coroutines",
    url: "/tv-remote-android",
    featured: true
  },
  {
    title: "Android TV Remote",
    category: "iOS App • Flutter",
    excerpt: "Control your Android & Google TV devices from your iPhone. Fast connection and beautiful material design.",
    techStack: "Flutter, Dart, iOS",
    url: "/android-tv-remote",
    featured: true
  },
  {
    title: "WiFi Mouse Remote",
    category: "Android & Desktop Client",
    excerpt: "Transform your Android device into a wireless mouse, keyboard, and trackpad for PC, Mac, and Linux.",
    techStack: "Compose Multiplatform, Java Sockets",
    url: "/wifi-mouse",
    featured: true
  },
  {
    title: "RMS (Restaurant Management API)",
    category: "REST-API Backend",
    excerpt: "A high-performance Restaurant Management System API built with Kotlin and Ktor.",
    techStack: "Kotlin, Ktor, PostgreSQL, Docker",
    url: "https://github.com/harimoradiya/rms",
    featured: false
  },
  {
    title: "StatusSaver",
    category: "Android App",
    excerpt: "A clean utility application to save statuses from social media platforms.",
    techStack: "Android, Kotlin",
    url: "https://github.com/harimoradiya/StatusSaver",
    featured: false
  },
  {
    title: "Background-Remover-App",
    category: "Android App & Backend",
    excerpt: "An image editing application to remove backgrounds utilizing local image processing.",
    techStack: "Android, Kotlin, Image Processing",
    url: "https://github.com/harimoradiya/Background-Remover-App",
    featured: false
  },
  {
    title: "NewsRoom",
    category: "Android App",
    excerpt: "A modern Android News Application building with Koin, Retrofit, and MVVM architecture.",
    techStack: "Android, Kotlin, Koin, Retrofit, MVVM",
    url: "https://github.com/harimoradiya/NewsRoom",
    featured: false
  }
];

const experiences = [
  {
    title: "Software Engineer",
    company: "Vasuka",
    period: "2022",
    description: "Developed and maintained multiple production-grade Android applications using Kotlin and Java. Implemented performance optimizations and modernized UI elements."
  }
];

const socialLinks = [ 
  { name: 'GitHub', url: 'https://github.com/harimoradiya', icon: 'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12' },
  { name: 'LinkedIn', url: 'https://www.linkedin.com/in/hari-moradiya-0a7145179/', icon: 'M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z' },
  { name: 'Twitter', url: 'https://twitter.com/hari_moradiya_', icon: 'M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z' },
  { name: 'Instagram', url: 'https://instagram.com/hk_moradiya', icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z' }
];

const resumeLink = 'https://drive.google.com/file/d/1N_zpQ09Z7lX21YmXd4Mj27x4h94fUa6X/view?usp=sharing';
---

<Layout>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-card">
      <div class="profile-avatar">HM</div>
      <h1 class="hero-title">Hello, I'm <span class="gradient-text">Hari Moradiya</span></h1>
      <p class="hero-subtitle">Software Engineer specializing in building premium Android applications, robust backend architectures, and high-quality software experiences.</p>
      
      <div class="hero-actions">
        <a href={resumeLink} target="_blank" rel="noopener noreferrer" class="btn-modern btn-modern-primary">
          <span>View Resume</span>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/hari-moradiya-0a7145179/" target="_blank" rel="noopener noreferrer" class="btn-modern btn-modern-secondary">
          <span>Get in Touch</span>
        </a>
      </div>

      <div class="social-links">
        {socialLinks.map(link => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label={link.name}>
            <svg viewBox="0 0 24 24" class="svg-icon">
              <path d={link.icon} />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="projects-section">
    <div class="section-header">
      <span class="eyebrow">Works</span>
      <h2 class="section-title">Featured Projects</h2>
      <p class="section-desc">Selected mobile applications and developer tools built with high performance and intuitive UX.</p>
    </div>

    <div class="projects-grid">
      {projects.map((project, index) => (
        <a href={project.url} class={`project-card ${project.featured ? 'featured-card' : ''}`} style={`animation-delay: ${index * 0.1}s`}>
          <div class="project-card-inner">
            <div class="project-meta-top">
              <span class="project-category">{project.category}</span>
              {project.featured && <span class="badge-featured">Featured</span>}
            </div>
            <h3 class="project-card-title">{project.title}</h3>
            <p class="project-excerpt">{project.excerpt}</p>
            <div class="project-meta-bottom">
              <span class="project-tech">{project.techStack}</span>
              <span class="project-link-action">
                <span>View Project</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Experience Section -->
  <section class="experience-section">
    <div class="section-header">
      <span class="eyebrow">Career</span>
      <h2 class="section-title">Work Experience</h2>
    </div>

    <div class="timeline-container">
      <div class="timeline-line"></div>
      {experiences.map((exp, index) => (
        <div class="timeline-item" style={`animation-delay: ${index * 0.15}s`}>
          <div class="timeline-node"></div>
          <div class="timeline-card">
            <div class="timeline-card-header">
              <div>
                <h3 class="exp-title">{exp.title}</h3>
                <p class="exp-company">{exp.company}</p>
              </div>
              <span class="exp-period">{exp.period}</span>
            </div>
            <p class="exp-desc">{exp.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <style>
    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes spinSlow {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    /* Hero Section Styles */
    .hero-section {
      min-height: 70vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem 0;
    }

    .hero-card {
      background: var(--bg-surface-glass);
      backdrop-filter: blur(var(--glass-blur));
      -webkit-backdrop-filter: blur(var(--glass-blur));
      border: 1px solid var(--border-color);
      box-shadow: var(--shadow-lg);
      border-radius: 32px;
      padding: 3.5rem 2rem;
      text-align: center;
      max-width: 800px;
      width: 100%;
      animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      position: relative;
      overflow: hidden;
    }

    /* Inner glowing border effect for hero card */
    .hero-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 32px;
      padding: 1.5px;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.25), transparent, rgba(168, 85, 247, 0.25));
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
    }

    .profile-avatar {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      background: linear-gradient(135deg, #4f46e5, #8b5cf6);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.25rem;
      font-weight: 800;
      margin: 0 auto 2rem auto;
      box-shadow: 0 8px 30px rgba(79, 70, 229, 0.3);
      position: relative;
    }

    .profile-avatar::after {
      content: '';
      position: absolute;
      inset: -5px;
      border-radius: 50%;
      border: 2px dashed var(--primary);
      opacity: 0.4;
      animation: spinSlow 20s linear infinite;
    }

    .hero-title {
      font-size: clamp(2.25rem, 5vw, 3.5rem);
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 1.25rem;
      letter-spacing: -0.03em;
      line-height: 1.15;
    }

    .gradient-text {
      background: linear-gradient(135deg, #4f46e5 30%, #8b5cf6 90%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .hero-subtitle {
      font-size: clamp(1.05rem, 2vw, 1.25rem);
      color: var(--text-secondary);
      line-height: 1.6;
      max-width: 620px;
      margin: 0 auto 2.5rem auto;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 2.5rem;
    }

    .social-links {
      display: flex;
      justify-content: center;
      gap: 1.25rem;
    }

    .social-icon-btn {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-secondary);
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: var(--shadow-sm);
      text-decoration: none;
    }

    .social-icon-btn:hover {
      transform: translateY(-3px);
      border-color: var(--primary);
      color: var(--primary);
      box-shadow: var(--shadow-md);
      background: var(--primary-glow);
    }

    .svg-icon {
      width: 20px;
      height: 20px;
      fill: currentColor;
    }

    /* Section Headers */
    .projects-section, .experience-section {
      padding: 5rem 0 2rem 0;
    }

    .section-header {
      margin-bottom: 3.5rem;
      text-align: center;
    }

    .eyebrow {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 0.75rem;
      display: block;
    }

    .section-title {
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }

    .section-desc {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.6;
    }

    /* Projects Grid */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.75rem;
    }

    .project-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: var(--card-radius);
      text-decoration: none;
      color: inherit;
      transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: var(--shadow-sm);
      opacity: 0;
      animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      overflow: hidden;
      display: flex;
    }

    .project-card-inner {
      padding: 2.25rem 2rem;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
    }

    .project-card:hover {
      transform: translateY(-6px);
      border-color: var(--primary);
      box-shadow: var(--shadow-lg), 0 10px 30px var(--border-glow);
    }

    .project-meta-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.25rem;
    }

    .project-category {
      font-size: 0.825rem;
      font-weight: 700;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .badge-featured {
      background: var(--primary-glow);
      color: var(--primary);
      padding: 0.25rem 0.75rem;
      border-radius: 99px;
      font-size: 0.75rem;
      font-weight: 700;
      border: 1.5px solid var(--primary);
    }

    .project-card-title {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 0.75rem;
      letter-spacing: -0.01em;
      line-height: 1.3;
    }

    .project-excerpt {
      color: var(--text-secondary);
      font-size: 0.975rem;
      line-height: 1.6;
      margin-bottom: 2rem;
      flex-grow: 1;
    }

    .project-meta-bottom {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      border-top: 1px solid var(--border-color);
      padding-top: 1.25rem;
    }

    .project-tech {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .project-link-action {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--primary);
      align-self: flex-start;
      transition: gap 0.25s ease;
    }

    .project-card:hover .project-link-action {
      gap: 0.75rem;
    }

    /* Experience Timeline Styles */
    .timeline-container {
      position: relative;
      max-width: 800px;
      margin: 0 auto;
      padding: 1rem 0;
    }

    .timeline-line {
      position: absolute;
      left: 20px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: var(--border-color);
    }

    .timeline-item {
      position: relative;
      padding-left: 50px;
      margin-bottom: 2.5rem;
      opacity: 0;
      animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .timeline-node {
      position: absolute;
      left: 11px;
      top: 24px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--bg-base);
      border: 4px solid var(--primary);
      z-index: 2;
      box-shadow: 0 0 10px rgba(79, 70, 229, 0.2);
    }

    .timeline-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: var(--card-radius);
      padding: 2rem;
      box-shadow: var(--shadow-sm);
      transition: all 0.3s ease;
    }

    .timeline-card:hover {
      box-shadow: var(--shadow-md);
      border-color: var(--primary);
    }

    .timeline-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1rem;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .exp-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .exp-company {
      font-size: 0.95rem;
      color: var(--primary);
      font-weight: 600;
      margin-top: 0.15rem;
    }

    .exp-period {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--text-muted);
      background: var(--bg-base);
      padding: 0.3rem 0.8rem;
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }

    .exp-desc {
      color: var(--text-secondary);
      font-size: 0.975rem;
      line-height: 1.6;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
      .hero-card {
        padding: 2.5rem 1.5rem;
      }
      .projects-grid {
        grid-template-columns: 1fr;
      }
      .timeline-card-header {
        flex-direction: column;
        gap: 0.5rem;
      }
      .exp-period {
        align-self: flex-start;
      }
    }
  </style>
</Layout>
