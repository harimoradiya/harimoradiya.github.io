  </style>

  <!-- Interactive script to control mockup TV screen -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tvScreen = document.getElementById('tv-screen');
      const tvStatus = document.getElementById('tv-status');
      const ledIndicator = document.querySelector('.tv-indicator');
      const remoteLed = document.querySelector('.remote-status-led');
      const volumeOverlay = document.getElementById('volume-overlay');
      const volumeFill = document.getElementById('volume-fill');
      
      const apps = ['youtube', 'netflix', 'prime'];
      let currentAppIndex = 0;
      let isTvOn = true;
      let volume = 50; // default volume percent
      let volumeTimeout: any = null;

      // Make indicator reflect TV on state
      ledIndicator?.classList.add('tv-on');

      // Add click listeners to remote control buttons
      const buttons = document.querySelectorAll('.phone-remote-container button');
      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const command = btn.getAttribute('data-command');
          if (!command) return;

          // Haptic feedback animation
          btn.classList.add('btn-pressed');
          setTimeout(() => btn.classList.remove('btn-pressed'), 150);

          if (command === 'POWER') {
            isTvOn = !isTvOn;
            if (isTvOn) {
              tvScreen?.classList.remove('tv-off');
              ledIndicator?.classList.add('tv-on');
              ledIndicator?.classList.remove('tv-off');
              remoteLed?.classList.add('connected');
              remoteLed?.classList.remove('tv-off');
              if (tvStatus) tvStatus.textContent = 'TV Ready';
            } else {
              tvScreen?.classList.add('tv-off');
              ledIndicator?.classList.remove('tv-on');
              ledIndicator?.classList.add('tv-off');
              remoteLed?.classList.remove('connected');
              remoteLed?.classList.add('tv-off');
            }
            return;
          }

          // If TV is off, remote actions do nothing
          if (!isTvOn) return;

          // Process commands
          switch(command) {
            case 'UP':
              changeAppSelection(-1);
              break;
            case 'DOWN':
              changeAppSelection(1);
              break;
            case 'LEFT':
              changeAppSelection(-1);
              break;
            case 'RIGHT':
              changeAppSelection(1);
              break;
            case 'SELECT':
              launchSelectedApp();
              break;
            case 'BACK':
              if (tvStatus) tvStatus.textContent = 'TV Home Menu';
              break;
            case 'HOME':
              if (tvStatus) tvStatus.textContent = 'Android TV Home';
              resetAppSelection();
              break;
            case 'VOL_UP':
              adjustVolume(5);
              break;
            case 'VOL_DOWN':
              adjustVolume(-5);
              break;
            case 'MUTE':
              toggleMute();
              break;
          }
        });
      });

      function changeAppSelection(direction: number) {
        // Remove active class from old app
        const currentAppId = `app-${apps[currentAppIndex]}`;
        document.getElementById(currentAppId)?.classList.remove('active-app');

        // Calculate new index
        currentAppIndex = (currentAppIndex + direction + apps.length) % apps.length;

        // Add active class to new app
        const nextAppId = `app-${apps[currentAppIndex]}`;
        document.getElementById(nextAppId)?.classList.add('active-app');

        if (tvStatus) {
          const appName = apps[currentAppIndex].charAt(0).toUpperCase() + apps[currentAppIndex].slice(1);
          tvStatus.textContent = `Select ${appName}`;
        }
      }

      function launchSelectedApp() {
        const appName = apps[currentAppIndex].charAt(0).toUpperCase() + apps[currentAppIndex].slice(1);
        if (tvStatus) {
          tvStatus.textContent = `Opening ${appName}...`;
        }
      }

      function resetAppSelection() {
        // Reset YouTube as default
        apps.forEach(app => {
          document.getElementById(`app-${app}`)?.classList.remove('active-app');
        });
        currentAppIndex = 0;
        document.getElementById(`app-youtube`)?.classList.add('active-app');
      }

      function adjustVolume(change: number) {
        volume = Math.max(0, Math.min(100, volume + change));
        
        if (volumeFill) {
          volumeFill.style.width = `${volume}%`;
        }

        // Show volume overlay
        volumeOverlay?.classList.add('show-vol');

        // Clear existing timeout
        if (volumeTimeout) clearTimeout(volumeTimeout);

        // Hide overlay after 1.5 seconds
        volumeTimeout = setTimeout(() => {
          volumeOverlay?.classList.remove('show-vol');
        }, 1500);

        if (tvStatus) {
          tvStatus.textContent = `Volume: ${volume}%`;
        }
      }

      let isMuted = false;
      let prevVolume = 50;

      function toggleMute() {
        if (isMuted) {
          volume = prevVolume;
          isMuted = false;
          adjustVolume(0);
        } else {
          prevVolume = volume;
          volume = 0;
          isMuted = true;
          adjustVolume(0);
          if (tvStatus) {
            tvStatus.textContent = `TV Muted`;
          }
        }
      }
    });
  </script>
</Layout>
