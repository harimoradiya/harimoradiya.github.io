    .setup-card {
      background: linear-gradient(135deg, var(--bg-surface), var(--bg-base));
      border: 1px solid var(--border-color);
      border-radius: 28px;
      padding: 3.5rem 2.5rem;
      box-shadow: var(--shadow-md);
    }

    .setup-card h2 {
