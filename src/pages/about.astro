---
import Layout from '../layouts/Layout.astro';
import SectionCard from '../components/about/SectionCard.astro';

const highlights = [
  { label: 'Years Building', value: '4+' },
  { label: 'Products Delivered', value: '20+' },
  { label: 'Cross-Platform Releases', value: '10+' },
  { label: 'Avg App Rating Focus', value: '4.8/5' },
];

const services = [
  'Android and iOS App Engineering',
  'Backend API Design and Integration',
  'Performance Optimization and Stability',
  'UI and UX Modernization',
];

const techStack = [
  'Kotlin',
  'Java',
  'Flutter',
  'Dart',
  'Ktor',
  'PostgreSQL',
  'Compose Multiplatform',
  'Material Design',
];

const journey = [
  { year: '2020', detail: 'Started shipping Android features with a user-first mindset.' },
  { year: '2022', detail: 'Joined product engineering at Vasuka and delivered production apps.' },
  { year: '2024', detail: 'Expanded into backend APIs, architecture, and reliability-led workflows.' },
  { year: '2026', detail: 'Building polished cross-platform products with faster release cycles.' },
];

const projects = [
  { name: 'Android TV Remote', impact: 'iOS remote experience with smooth media and D-pad workflows.' },
  { name: 'WiFi Mouse Remote', impact: 'Connected mobile and desktop control with low-latency input.' },
  { name: 'RMS API', impact: 'Scalable restaurant backend APIs with Kotlin and PostgreSQL.' },
];
---

<Layout>
  <div class="about-page">
    <section class="hero">
      <div class="hero-panel">
        <p class="eyebrow">About Us</p>
        <h1>Harikrushn Devjibhai Moradiya</h1>
        <p class="lead">
          Software engineer focused on premium mobile and backend experiences. I build reliable, elegant products that feel fast, clear, and production-ready.
        </p>
        <div class="hero-actions">
          <a href="#mission" class="btn-primary">Mission and Vision</a>
          <a href="#journey" class="btn-secondary">View Journey</a>
        </div>
      </div>
    </section>

    <section class="grid stats-grid" aria-label="Achievements">
      {highlights.map((item) => (
        <article class="stat-card">
          <p class="stat-value">{item.value}</p>
          <p class="stat-label">{item.label}</p>
        </article>
      ))}
    </section>

    <section class="grid two-col">
      <SectionCard title="Story" subtitle="Built with ownership, clarity, and consistency.">
        <p>
          My legal name is Harikrushn Devjibhai Moradiya. I started by building Android apps, then moved into full product delivery including iOS-ready workflows and backend systems. Every release is shaped around user trust, performance, and long-term maintainability.
        </p>
      </SectionCard>
      <SectionCard title="Experience Highlights" subtitle="Core areas where I consistently deliver impact.">
        <ul class="clean-list">
          <li>Production app delivery with Kotlin, Flutter, and modern UI architecture.</li>
          <li>Backend API implementation with Ktor, PostgreSQL, and robust integration patterns.</li>
          <li>Bug reduction and release quality improvements through focused engineering practices.</li>
        </ul>
      </SectionCard>
    </section>

    <section id="mission" class="grid two-col">
      <SectionCard title="Mission">
        <p>
          Deliver software that is simple to use, stable at scale, and pleasant to interact with across devices.
        </p>
      </SectionCard>
      <SectionCard title="Vision">
        <p>
          Build trusted digital products where design quality and engineering reliability are equally strong.
        </p>
      </SectionCard>
    </section>

    <section class="grid two-col">
      <SectionCard title="Skills and Services">
        <div class="chip-grid">
          {services.map((service) => <span class="chip">{service}</span>)}
        </div>
      </SectionCard>
      <SectionCard title="Tech Stack">
        <div class="chip-grid">
          {techStack.map((tech) => <span class="chip">{tech}</span>)}
        </div>
      </SectionCard>
    </section>

    <section id="journey">
      <SectionCard title="Journey Timeline">
        <div class="timeline">
          {journey.map((step) => (
            <div class="timeline-item">
              <p class="timeline-year">{step.year}</p>
              <p class="timeline-detail">{step.detail}</p>
            </div>
          ))}
        </div>
      </SectionCard>
    </section>

    <section>
      <SectionCard title="Client and Project Highlights" subtitle="Selected outcomes from recent work.">
        <div class="project-grid">
          {projects.map((project) => (
            <article class="project-card">
              <h3>{project.name}</h3>
              <p>{project.impact}</p>
            </article>
          ))}
        </div>
      </SectionCard>
    </section>

    <section class="cta">
      <div class="cta-card">
        <h2>Let’s Build Something Strong Together</h2>
        <p>
          If you are looking for a reliable engineer for mobile or backend product delivery, let’s connect and build your next release.
        </p>
        <a href="https://www.linkedin.com/in/hari-moradiya-0a7145179/" target="_blank" rel="noopener noreferrer" class="btn-primary">Start a Conversation</a>
      </div>
    </section>
  </div>

  <style>
    .about-page {
      display: grid;
      gap: 1.5rem;
      scroll-behavior: smooth;
    }

    .hero {
      background: linear-gradient(135deg, var(--primary-container), color-mix(in srgb, var(--surface-variant) 70%, var(--surface)));
      border-radius: 24px;
      padding: clamp(1.2rem, 2vw, 2.4rem);
      border: 1px solid color-mix(in srgb, var(--outline) 45%, transparent);
    }

    .hero-panel {
      background: color-mix(in srgb, var(--surface) 74%, transparent);
      border: 1px solid color-mix(in srgb, var(--outline) 36%, transparent);
      border-radius: 18px;
      backdrop-filter: blur(12px);
      padding: clamp(1.1rem, 2vw, 2.2rem);
    }

    .eyebrow {
      font-size: 0.85rem;
      color: var(--primary);
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }

    h1 {
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.1;
      margin-bottom: 0.9rem;
    }

    .lead {
      color: var(--on-surface-variant);
      line-height: 1.7;
      max-width: 800px;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .btn-primary,
    .btn-secondary {
      text-decoration: none;
      border-radius: 10px;
      padding: 0.65rem 1rem;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      font-weight: 600;
    }

    .btn-primary {
      background: var(--primary);
      color: var(--on-primary);
      box-shadow: var(--elevation-1);
    }

    .btn-secondary {
      border: 1px solid var(--outline);
      color: var(--on-surface);
    }

    .btn-primary:hover,
    .btn-secondary:hover {
      transform: translateY(-2px);
      box-shadow: var(--elevation-2);
    }

    .grid {
      display: grid;
      gap: 1rem;
    }

    .stats-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .stat-card {
      border-radius: 16px;
      border: 1px solid color-mix(in srgb, var(--outline) 45%, transparent);
      background: color-mix(in srgb, var(--surface) 78%, transparent);
      padding: 1rem;
      text-align: center;
      transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .stat-card:hover {
      transform: translateY(-3px);
      border-color: color-mix(in srgb, var(--primary) 35%, var(--outline));
    }

    .stat-value {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--on-surface);
    }

    .stat-label {
      margin-top: 0.2rem;
      color: var(--on-surface-variant);
      font-size: 0.95rem;
    }

    .two-col {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .clean-list {
      padding-left: 1.15rem;
      color: var(--on-surface-variant);
      display: grid;
      gap: 0.5rem;
      line-height: 1.6;
    }

    .chip-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
    }

    .chip {
      border: 1px solid color-mix(in srgb, var(--outline) 40%, transparent);
      background: color-mix(in srgb, var(--primary-container) 30%, var(--surface));
      color: var(--on-surface);
      padding: 0.45rem 0.85rem;
      border-radius: 999px;
      font-size: 0.9rem;
    }

    .timeline {
      display: grid;
      gap: 0.9rem;
    }

    .timeline-item {
      border-left: 3px solid var(--primary);
      padding-left: 0.8rem;
    }

    .timeline-year {
      color: var(--on-surface);
      font-weight: 700;
      margin-bottom: 0.25rem;
    }

    .timeline-detail {
      color: var(--on-surface-variant);
      line-height: 1.6;
    }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .project-card {
      border: 1px solid color-mix(in srgb, var(--outline) 42%, transparent);
      border-radius: 14px;
      padding: 1rem;
      background: color-mix(in srgb, var(--surface) 75%, transparent);
    }

    .project-card h3 {
      font-size: 1.05rem;
      margin-bottom: 0.45rem;
    }

    .project-card p {
      color: var(--on-surface-variant);
      line-height: 1.55;
      font-size: 0.95rem;
    }

    .cta-card {
      border-radius: 20px;
      padding: clamp(1.2rem, 2vw, 2rem);
      border: 1px solid color-mix(in srgb, var(--primary) 35%, var(--outline));
      background: linear-gradient(135deg, color-mix(in srgb, var(--primary-container) 50%, var(--surface)), var(--surface));
      text-align: center;
    }

    .cta-card h2 {
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      margin-bottom: 0.75rem;
    }

    .cta-card p {
      color: var(--on-surface-variant);
      max-width: 720px;
      margin: 0 auto 1rem auto;
      line-height: 1.7;
    }

    @media (max-width: 1024px) {
      .stats-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .project-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 768px) {
      .two-col,
      .stats-grid,
      .project-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
