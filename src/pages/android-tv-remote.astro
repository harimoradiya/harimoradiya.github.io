---
// src/pages/android-tv-remote.astro
import Layout from '../layouts/Layout.astro';
import a1 from '../assets/a1.png';
import a2 from '../assets/a2.png';
import a3 from '../assets/a3.png';
import a4 from '../assets/a4.png';
import a5 from '../assets/a5.png';
import a6 from '../assets/a6.png';

const screenshots = [a1, a2, a3, a4, a5, a6];
---

<Layout>
  <div class="product-page">
    <!-- Hero Section -->
    <section class="hero-split">
      <div class="hero-info">
        <span class="product-badge">iOS Application</span>
        <h1 class="product-title">Android TV <span class="gradient-text">Remote Control</span></h1>
        <p class="product-description">
          Control your Android TV or Google TV device directly from your iPhone. A fast, secure, and beautiful interface designed natively to mimic the official D-pad, media, and voice workflows.
        </p>
        <div class="cta-actions">
          <a href="https://apps.apple.com/us/app/wifi-remote-for-android-tv/id6763198238" class="btn-modern btn-modern-primary" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.1 22C7.79 22.05 6.8 20.68 5.96 19.47C4.25 17 2.94 12.45 4.7 9.39C5.57 7.87 7.13 6.91 8.82 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.1 16.67C20.08 16.74 19.67 18.11 18.71 19.5M15.97 4.17C16.63 3.37 17.07 2.28 16.95 1C16 1.04 14.9 1.6 14.24 2.38C13.68 3.04 13.19 4.14 13.34 5.39C14.39 5.47 15.4 4.88 15.97 4.17Z"/>
            </svg>
            <span>Download on App Store</span>
          </a>
          <a href="#features" class="btn-modern btn-modern-secondary">
            <span>Explore Features</span>
          </a>
        </div>
      </div>
      
      <div class="hero-visual">
        <div class="visual-card">
          <div class="card-icon">📺</div>
          <h3>D-Pad Nav</h3>
          <p>Zero connection lag</p>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features-section">
      <div class="section-header">
        <span class="eyebrow">Features</span>
        <h2 class="section-title">Everything You Need</h2>
        <p class="section-desc">We built the ultimate iOS-to-Android-TV utility focusing on performance and premium layouts.</p>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🎮</div>
          <h3>Precise D-Pad</h3>
          <p>Highly tactile direction pad for menu browsing, options lists, and fast scrolling.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎬</div>
          <h3>Media Controller</h3>
          <p>Dedicated keys for play, pause, seek, volume adjustments, and mute workflows.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⌨️</div>
          <h3>Quick Keyboard</h3>
          <p>Full QWERTY input capabilities from your iPhone keyboard direct to the TV screen.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🚀</div>
          <h3>App Launcher</h3>
          <p>Quick access launcher to open Netflix, YouTube, Prime, and more in one click.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎙️</div>
          <h3>Voice Commands</h3>
          <p>Utilize voice commands to browse your TV channels or perform universal search queries.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Auto Discovery</h3>
          <p>Local WiFi scans detect your Android TV or Google TV instantly on launch.</p>
        </div>
      </div>
    </section>

    <!-- Preview Gallery -->
    <section class="gallery-section">
      <div class="section-header">
        <span class="eyebrow">Screenshots</span>
        <h2 class="section-title">App Preview</h2>
      </div>

      <div class="gallery-grid">
        {screenshots.map((screen, idx) => (
          <div class="gallery-item" style={`animation-delay: ${idx * 0.1}s`}>
            <img src={screen.src} alt={`iOS App Preview Screenshot ${idx + 1}`} loading="lazy" />
          </div>
        ))}
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="tech-stack-section">
      <div class="tech-card">
        <h3>Built With Industry Standard Tech</h3>
        <div class="tech-badges">
          <span class="tech-badge">Flutter</span>
          <span class="tech-badge">iOS Native</span>
          <span class="tech-badge">Dart</span>
          <span class="tech-badge">Material Design 3</span>
        </div>
      </div>
    </section>

    <!-- Download Call to Action -->
    <section class="cta-bottom">
      <div class="cta-card">
        <h2>Ready to Control Your TV?</h2>
        <p>Get the premium remote app from the App Store and start controlling your Google TV or Android TV today.</p>
        <a href="https://apps.apple.com/us/app/wifi-remote-for-android-tv/id6763198238" class="btn-modern btn-modern-primary" target="_blank" rel="noopener noreferrer">
          Download on App Store
        </a>
      </div>
    </section>
  </div>

  <style>
    .product-page {
      display: flex;
      flex-direction: column;
      gap: 5rem;
      padding-top: 1rem;
    }

    /* Hero Section */
    .hero-split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 4rem;
      min-height: 80vh;
    }

    .hero-info {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .product-badge {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .product-title {
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 800;
      color: var(--text-primary);
      line-height: 1.1;
      letter-spacing: -0.03em;
    }

    .gradient-text {
      background: linear-gradient(135deg, #4f46e5 20%, #8b5cf6 90%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .product-description {
      font-size: 1.15rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .cta-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .hero-visual {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-16px); }
    }

    .visual-card {
      width: 220px;
      height: 220px;
      background: linear-gradient(135deg, #4f46e5, #8b5cf6);
      border-radius: 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      color: white;
      box-shadow: 0 20px 40px rgba(79, 70, 229, 0.25);
      animation: float 6s ease-in-out infinite;
      text-align: center;
    }

    .card-icon {
      font-size: 3rem;
    }

    .visual-card h3 {
      font-size: 1.25rem;
      font-weight: 700;
      margin: 0;
    }

    .visual-card p {
      font-size: 0.85rem;
      opacity: 0.85;
      margin: 0;
    }

    /* Features Grid */
    .features-section {
      padding: 3rem 0 1rem 0;
    }

    .section-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .eyebrow {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 0.75rem;
      display: block;
    }

    .section-title {
      font-size: 2.25rem;
      font-weight: 800;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }

    .section-desc {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }

    .feature-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: var(--card-radius);
      padding: 2.5rem 2rem;
      box-shadow: var(--shadow-sm);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .feature-card:hover {
      transform: translateY(-5px);
      border-color: var(--primary);
      box-shadow: var(--shadow-lg);
    }

    .feature-icon {
      font-size: 2.25rem;
      margin-bottom: 1.25rem;
    }

    .feature-card h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .feature-card p {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    /* Screenshots Gallery */
    .gallery-section {
      padding: 3rem 0;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1.5rem;
    }

    .gallery-item {
      border-radius: 18px;
      overflow: hidden;
      aspect-ratio: 9 / 19;
      box-shadow: var(--shadow-md);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      border: 1px solid var(--border-color);
      background: var(--bg-surface);
    }

    .gallery-item:hover {
      transform: scale(1.04) translateY(-4px);
      box-shadow: var(--shadow-xl);
      border-color: var(--primary);
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Tech Stack */
    .tech-stack-section {
      padding: 1rem 0;
    }

    .tech-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: var(--card-radius);
      padding: 2.5rem;
      text-align: center;
      box-shadow: var(--shadow-sm);
    }

    .tech-card h3 {
      font-size: 1.25rem;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
    }

    .tech-badges {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.75rem;
    }

    .tech-badge {
      background: var(--bg-base);
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      padding: 0.5rem 1.25rem;
      border-radius: 99px;
      font-size: 0.9rem;
      font-weight: 600;
    }

    /* Call to Action */
    .cta-bottom {
      padding: 2rem 0;
    }

    .cta-card {
      background: linear-gradient(135deg, var(--bg-surface), var(--bg-base));
      border: 1px solid var(--border-color);
      border-radius: 28px;
      padding: 3.5rem 2rem;
      text-align: center;
      box-shadow: var(--shadow-md);
    }

    .cta-card h2 {
      font-size: 2rem;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 1rem;
    }

    .cta-card p {
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto 2rem auto;
      line-height: 1.6;
      font-size: 1.05rem;
    }

    /* Responsive adjustments */
    @media (max-width: 1024px) {
      .hero-split {
        grid-template-columns: 1fr;
        gap: 3rem;
        text-align: center;
      }

      .hero-info {
        align-items: center;
      }

      .cta-actions {
        justify-content: center;
      }

      .hero-visual {
        display: none;
      }

      .gallery-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 576px) {
      .gallery-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</Layout>
