---
// src/pages/wifi-mouse.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="product-container">
    <!-- Hero Section with Gradient Background -->
    <section class="hero-section">
      <div class="hero-background"></div>
      <div class="product-header">
        <div class="badge-intro">Remote Control Solution</div>
        <h1 class="hero-title">WiFi Mouse Remote Control</h1>
        <p class="tagline">Transform your Android device into a powerful wireless mouse and keyboard for PC, Mac, and Linux</p>
        <div class="tech-badge-container">
          <span class="tech-badge">Android</span>
          <span class="tech-badge">Kotlin</span>
          <span class="tech-badge">Material Design</span>
          <span class="tech-badge">Jetpack Compose</span>
          <span class="tech-badge">Multiplatform</span>
        </div>
        <div class="hero-cta">
          <a href="#download" class="cta-primary">
            <span>Get Started</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10h12M10 4l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </a>
          <a href="https://github.com/harimoradiya/WiFi-Mouse-Android-Client" target="_blank" class="cta-secondary">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10 0C4.477 0 0 4.477 0 10c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0110 4.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C17.137 18.165 20 14.418 20 10c0-5.523-4.477-10-10-10z"/>
            </svg>
            <span>View on GitHub</span>
          </a>
        </div>
      </div>
    </section>

    <!-- App Overview with Visual Card -->
    <section class="app-overview">
      <div class="overview-visual">
        <div class="phone-mockup">
          <div class="phone-frame">
            <div class="phone-notch"></div>
            <div class="phone-screen">
              <div class="app-ui">
                <div class="ui-header">
                  <div class="status-bar">
                    <span>9:41</span>
                    <div class="status-icons">
                      <span>📶</span>
                      <span>🔋</span>
                    </div>
                  </div>
                  <h3>WiFi Mouse</h3>
                  <div class="connection-status connected">
                    <span class="status-dot"></span>
                    Connected
                  </div>
                </div>
                <div class="touchpad-area">
                  <div class="cursor-indicator"></div>
                  <span class="touchpad-hint">Touch to control</span>
                </div>
                <div class="control-buttons">
                  <button class="control-btn">L</button>
                  <button class="control-btn">R</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="overview-content">
        <span class="section-label">About the App</span>
        <h2>Control Your Computer from Anywhere in the Room</h2>
        <p>
          Transform your Android device into a wireless mouse and keyboard controller. Our Kotlin Multiplatform solution provides seamless connectivity between your phone and computer with intuitive touch gestures, full keyboard support, and real-time connection management.
        </p>
        <div class="feature-highlights">
          <div class="highlight-item">
            <div class="highlight-icon">✓</div>
            <div>
              <strong>Precise Control</strong>
              <span>Smooth cursor movement with multi-touch gestures</span>
            </div>
          </div>
          <div class="highlight-item">
            <div class="highlight-icon">✓</div>
            <div>
              <strong>Secure Connection</strong>
              <span>Local WiFi only, no internet required</span>
            </div>
          </div>
          <div class="highlight-item">
            <div class="highlight-icon">✓</div>
            <div>
              <strong>Cross-Platform</strong>
              <span>Works with Windows, macOS, and Linux</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Grid -->
    <section class="features-section">
      <span class="section-label">Features</span>
      <h2>Everything You Need for Remote Control</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">🖱️</div>
          </div>
          <h3>Precise Mouse Control</h3>
          <p>Transform your touchscreen into a responsive wireless mouse with smooth cursor movement and intuitive multi-touch gestures.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">⌨️</div>
          </div>
          <h3>Full QWERTY Keyboard</h3>
          <p>Complete keyboard input with function keys, special characters, and system shortcuts for seamless typing.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">📱</div>
          </div>
          <h3>Cross-Platform Server</h3>
          <p>Kotlin Multiplatform server supports Windows, macOS, and Linux with real-time device monitoring.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">🚀</div>
          </div>
          <h3>App Launcher</h3>
          <p>View and launch installed applications remotely with search functionality and instant access.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">📡</div>
          </div>
          <h3>WiFi Connection</h3>
          <p>Secure local network communication with easy IP and port setup - no internet required.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">🔒</div>
          </div>
          <h3>Privacy Focused</h3>
          <p>All communication stays on your local network with open-source transparency.</p>
        </div>
      </div>
    </section>

    <!-- How to Use -->
    <section class="how-to-use-section">
      <span class="section-label">Setup Guide</span>
      <h2>Get Started in 4 Simple Steps</h2>
      <div class="usage-steps">
        <div class="step-card">
          <div class="step-number">1</div>
          <h3>Install Server</h3>
          <p>Download and install the WiFi Mouse Server on your computer (Windows, macOS, or Linux). Run with admin privileges and note the IP address.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step-card">
          <div class="step-number">2</div>
          <h3>Install App</h3>
          <p>Download WiFi Mouse from Play Store on your Android device. Grant network permissions and ensure both devices are on the same WiFi.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step-card">
          <div class="step-number">3</div>
          <h3>Connect Devices</h3>
          <p>Open the app, tap Auto Connect, or scan the QR code from your server. Your device will appear automatically.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step-card">
          <div class="step-number">4</div>
          <h3>Start Controlling</h3>
          <p>Slide to move cursor, tap for clicks, two-finger swipe to scroll. Access keyboard and app launcher from the menu.</p>
        </div>
      </div>

      <div class="usage-tips">
        <h3>Pro Tips</h3>
        <div class="tips-grid">
          <div class="tip-card">
            <div class="tip-icon">📡</div>
            <strong>Network</strong>
            <p>Both devices must be on the same WiFi network</p>
          </div>
          <div class="tip-card">
            <div class="tip-icon">🛡️</div>
            <strong>Firewall</strong>
            <p>Allow TCP port 8080 through your firewall</p>
          </div>
          <div class="tip-card">
            <div class="tip-icon">🔓</div>
            <strong>Permissions</strong>
            <p>Grant accessibility permissions for full control</p>
          </div>
          <div class="tip-card">
            <div class="tip-icon">👆</div>
            <strong>Gestures</strong>
            <p>Use multi-touch for drag & drop operations</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Download Section -->
    <section id="download" class="download-section">
      <div class="download-content">
        <span class="section-label light">Download</span>
        <h2>Get WiFi Mouse</h2>
        <p class="download-description">Complete solution with Android client and desktop server for seamless remote control</p>
        
        <div class="download-grid">
          <div class="download-category">
            <h3>
              <span class="category-icon">📱</span>
              Android Client
            </h3>
            <a href="https://drive.google.com/file/d/1ljIjfxRG_9M9fhVM53dYD2dN3HggZwQM/view?usp=sharing" 
   class="download-button play-store"
   target="_blank" 
   rel="noopener noreferrer">
  <div class="button-content">
    <div class="button-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
      </svg>
    </div>
    <div class="button-text">
      <span class="button-label">Get on Android</span>
      <span class="button-sub">Available Now</span>
    </div>
  </div>
</a>

          </div>

          <div class="download-category">
            <h3>
              <span class="category-icon">💻</span>
              Desktop Server
            </h3>
            <div class="server-downloads">
              <a href="#" class="download-button windows">
                <div class="button-content">
                  <div class="button-icon">🪟</div>
                  <div class="button-text">
                    <span class="button-label">Windows</span>
                    <span class="button-sub">Coming soon</span>
                  </div>
                </div>
              </a>
              <a href="https://drive.google.com/file/d/1SXdOkgwEoOF-YsWK0ZoSOu-bvW8ymIhJ/view?usp=sharing" class="download-button mac" target="_blank" rel="noopener noreferrer">
                <div class="button-content">
                  <div class="button-icon">🍎</div>
                  <div class="button-text">
                    <span class="button-label">macOS</span>
                    <span class="button-sub">v1.0.0 • 79 MB(Available)</span>
                  </div>
                </div>
              </a>
              <a href="#" class="download-button linux">
                <div class="button-content">
                  <div class="button-icon">🐧</div>
                  <div class="button-text">
                    <span class="button-label">Linux</span>
                    <span class="button-sub">Coming soon</span>
                  </div>
                </div>
              </a>
            </div>
          </div>
        </div>

        <div class="requirements-grid">
          <div class="requirement-card">
            <h4>Android Requirements</h4>
            <ul>
              <li>Android 5.0 (API 21) or higher</li>
              <li>WiFi network connection</li>
              <li>10MB free storage</li>
              <li>Network access permissions</li>
            </ul>
          </div>
          <div class="requirement-card">
            <h4>Desktop Requirements</h4>
            <ul>
              <li>Windows 10/11, macOS 10.14+, or Linux</li>
              <li>Java Runtime Environment (JDK 11+)</li>
              <li>WiFi network connection</li>
              <li>Accessibility permissions</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <span class="section-label">FAQ</span>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question">
            <span>Is WiFi Mouse free to use?</span>
            <svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
          <div class="faq-answer">
            <p>Yes, WiFi Mouse is completely free to use with no hidden charges or in-app purchases.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Do both devices need to be on the same network?</span>
            <svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
          <div class="faq-answer">
            <p>Yes, both your Android device and computer must be connected to the same WiFi network for the app to function properly.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Does it work without internet connection?</span>
            <svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
          <div class="faq-answer">
            <p>Yes! WiFi Mouse only requires a local WiFi network. No internet connection is needed as all communication stays on your local network.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Is my data secure?</span>
            <svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
          <div class="faq-answer">
            <p>Absolutely. All communication happens on your local network only. We don't collect or transmit any data outside your network, and the app is open-source for transparency.</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  :root {
    --primary: #6366f1;
    --primary-dark: #4f46e5;
    --primary-light: #818cf8;
    --secondary: #10b981;
    --surface: #ffffff;
    --surface-variant: #f8fafc;
    --surface-dark: #1e293b;
    --on-surface: #0f172a;
    --on-surface-variant: #64748b;
    --border: #e2e8f0;
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
    --radius: 16px;
    --radius-sm: 8px;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .product-container {
    width: 100%;
    overflow-x: hidden;
  }

  /* Hero Section */
  .hero-section {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    opacity: 0.05;
  }

  .hero-background::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 50%, rgba(99, 102, 241, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(168, 85, 247, 0.1) 0%, transparent 50%);
  }

  .product-header {
    position: relative;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    animation: fadeInUp 0.8s ease forwards;
  }

  .badge-intro {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: var(--primary-light);
    color: white;
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.8s 0.2s ease forwards;
    opacity: 0;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    color: var(--on-surface);
    margin-bottom: 1.5rem;
    line-height: 1.1;
    animation: fadeInUp 0.8s 0.3s ease forwards;
    opacity: 0;
  }

  .tagline {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--on-surface-variant);
    margin-bottom: 2.5rem;
    line-height: 1.6;
    animation: fadeInUp 0.8s 0.4s ease forwards;
    opacity: 0;
  }

  .tech-badge-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
    animation: fadeInUp 0.8s 0.5s ease forwards;
    opacity: 0;
  }

  .tech-badge {
    padding: 0.5rem 1.25rem;
    background: var(--primary-container);
    color: var(--on-primary-container);
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 600;
    border: 2px solid var(--outline);
    transition: all 0.3s ease;
  }

  .tech-badge:hover {
    transform: translateY(-2px);
    border-color: var(--primary);
    box-shadow: var(--shadow);
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeInUp 0.8s 0.6s ease forwards;
    opacity: 0;
  }

  .cta-primary, .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: 1.1rem;
  }

  .cta-primary {
    background: var(--primary);
    color: var(--on-primary);
  }

  .cta-secondary {
    background: var(--primary-container);
    color: var(--on-primary-container);
  }

  .cta-primary {
    background: var(--primary);
    color: white;
    box-shadow: var(--shadow);
  }

  .cta-primary:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .cta-secondary {
    background: var(--surface);
    color: var(--on-surface);
    border: 2px solid var(--border);
  }

  .cta-secondary:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  /* App Overview */
  .app-overview {
    max-width: 1200px;
    margin: 6rem auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-label {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .section-label.light {
    color: rgba(255, 255, 255, 0.9);
  }

  .overview-content h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--on-surface);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .overview-content p {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--on-surface-variant);
    margin-bottom: 2rem;
  }

  .feature-highlights {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .highlight-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .highlight-icon {
    width: 32px;
    height: 32px;
    background: var(--secondary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-weight: 700;
  }

  .highlight-item strong {
    display: block;
    color: var(--on-surface);
    margin-bottom: 0.25rem;
  }

  .highlight-item span {
    color: var(--on-surface-variant);
    font-size: 0.9rem;
  }

  /* Phone Mockup */
  .phone-mockup {
    perspective: 1000px;
  }

  .phone-frame {
    background: linear-gradient(145deg, #2d3748, #1a202c);
    border-radius: 48px;
    padding: 12px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
    transition: transform 0.3s ease;
    animation: float 6s ease-in-out infinite;
  }

  .phone-frame:hover {
    transform: rotateY(5deg) rotateX(5deg);
  }

  .phone-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 28px;
    background: #1a202c;
    border-radius: 0 0 20px 20px;
    z-index: 10;
  }

  .phone-screen {
    background: var(--surface);
    border-radius: 40px;
    height: 600px;
    position: relative;
    overflow: hidden;
  }

  .app-ui {
    padding: 2rem 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .status-bar {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--on-surface-variant);
    margin-bottom: 1.5rem;
  }

  .status-icons {
    display: flex;
    gap: 0.5rem;
  }

  .ui-header h3 {
    font-size: 1.5rem;
    color: var(--on-surface);
    margin-bottom: 1rem;
  }

  .connection-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: #dcfce7;
    color: #166534;
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: #16a34a;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  .touchpad-area {
    flex: 1;
    background: var(--surface-variant);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-bottom: 1rem;
  }

  .cursor-indicator {
    width: 12px;
    height: 12px;
    background: var(--primary);
    border-radius: 50%;
    position: absolute;
    animation: moveCursor 4s ease-in-out infinite;
  }

  .touchpad-hint {
    color: var(--on-surface-variant);
    font-size: 0.875rem;
