---
// src/pages/wifi-mouse.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="product-page">
    <!-- Hero & Mockup Section -->
    <section class="hero-split">
      <div class="hero-info">
        <span class="product-badge">Android & Desktop Utility</span>
        <h1 class="product-title">WiFi Mouse <span class="gradient-text">Remote Control</span></h1>
        <p class="product-description">
          Transform your Android device into a powerful wireless mouse, keyboard, and application launcher for your computer. Connect securely over local WiFi with zero latency.
        </p>
        <div class="cta-actions">
          <a href="#download" class="btn-modern btn-modern-primary">
            <span>Get Started</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 10h12M10 4l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="https://github.com/harimoradiya/WiFi-Mouse-Android-Client" target="_blank" rel="noopener noreferrer" class="btn-modern btn-modern-secondary">
            <!-- GitHub Icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
            <span>View on GitHub</span>
          </a>
        </div>
      </div>

      <!-- App Mockup -->
      <div class="interactive-sandbox">
        <div class="phone-frame">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="app-ui">
              <div class="ui-header">
                <div class="status-bar">
                  <span>9:41 AM</span>
                  <div class="status-icons">📶 🔋</div>
                </div>
                <h3>WiFi Mouse</h3>
                <div class="connection-status connected">
                  <span class="status-dot"></span>
                  Connected
                </div>
              </div>
              <div class="touchpad-area">
                <div class="cursor-indicator animate-cursor"></div>
                <span class="touchpad-hint">Swipe to control cursor</span>
              </div>
              <div class="control-buttons">
                <button class="control-btn">Left Click</button>
                <button class="control-btn">Right Click</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- App Highlights -->
    <section class="info-section">
      <div class="section-header">
        <span class="eyebrow">Overview</span>
        <h2 class="section-title">Wireless Desktop Control</h2>
        <p class="section-desc">Our Kotlin Multiplatform solution provides a lightweight server and client to control PCs remotely.</p>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon-wrapper">🖱️</div>
          <h3>Tactile Mouse Control</h3>
          <p>Touchpad gesture simulation, scroll triggers, click states, and velocity-based tracking.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrapper">⌨️</div>
          <h3>Full QWERTY Input</h3>
          <p>Send text, keyboard shortcuts, special function characters, and system actions.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrapper">🚀</div>
          <h3>Desktop App Launcher</h3>
          <p>Initiate applications directly from your phone and filter your target items with ease.</p>
        </div>
      </div>
    </section>

    <!-- Setup Guide -->
    <section class="setup-guide-section">
      <div class="section-header">
        <span class="eyebrow">Setup</span>
        <h2 class="section-title">Get Started in 4 Steps</h2>
      </div>

      <div class="steps-timeline">
        <div class="step-card">
          <div class="step-num">1</div>
          <h4>Install Server</h4>
          <p>Download WiFi Mouse Server on your PC (Windows, macOS, Linux). Allow administrator permissions.</p>
        </div>
        <div class="step-card">
          <div class="step-num">2</div>
          <h4>Download Client</h4>
          <p>Download the WiFi Mouse application from Google Play on your Android smartphone device.</p>
        </div>
        <div class="step-card">
          <div class="step-num">3</div>
          <h4>Pair Devices</h4>
          <p>Ensure both phone and computer connect to the same WiFi network. Pair via IP or auto-discover scans.</p>
        </div>
        <div class="step-card">
          <div class="step-num">4</div>
          <h4>Ready to Control</h4>
          <p>Slide on the touchpad area to direct cursor movements. Use buttons for Left and Right mouse clicks.</p>
        </div>
      </div>
    </section>

    <!-- Download Grid -->
    <section id="download" class="download-section">
      <div class="section-header">
        <span class="eyebrow">Downloads</span>
        <h2 class="section-title">Get WiFi Mouse</h2>
      </div>

      <div class="download-container-box">
        <div class="download-grid">
          <!-- Client download card -->
          <div class="download-card-box">
            <h3>📱 Android Client App</h3>
            <p>Download the client APK file to run on your Android mobile device.</p>
            <a href="https://drive.google.com/file/d/1ljIjfxRG_9M9fhVM53dYD2dN3HggZwQM/view?usp=sharing" target="_blank" rel="noopener noreferrer" class="btn-modern btn-modern-primary download-btn-style">
              Download Client APK
            </a>
          </div>

          <!-- Server download card -->
          <div class="download-card-box">
            <h3>💻 Desktop Server App</h3>
            <p>Download the corresponding server utility tool to run on your computer host.</p>
            <div class="server-links-group">
              <a href="https://drive.google.com/file/d/1SXdOkgwEoOF-YsWK0ZoSOu-bvW8ymIhJ/view?usp=sharing" target="_blank" rel="noopener noreferrer" class="server-link-pill">
                🍎 macOS Server (Available)
              </a>
              <span class="server-link-pill disabled">
                🪟 Windows Server (Coming Soon)
              </span>
              <span class="server-link-pill disabled">
                🐧 Linux Server (Coming Soon)
              </span>
            </div>
          </div>
        </div>

        <div class="requirements-wrapper">
          <div class="req-col">
            <h5>Android Requirements</h5>
            <ul>
              <li>Android 5.0 (API 21) or higher</li>
              <li>Local WiFi network connection</li>
              <li>Network socket access permissions</li>
            </ul>
          </div>
          <div class="req-col">
            <h5>Computer Requirements</h5>
            <ul>
              <li>macOS 10.14+, Windows 10/11, or Linux</li>
              <li>Java Runtime (JDK 11+) installed</li>
              <li>Port 8080 allowed in Firewalls</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="section-header">
        <span class="eyebrow">FAQ</span>
        <h2 class="section-title">Frequently Asked Questions</h2>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question">
            <span>Is WiFi Mouse free to use?</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <p>Yes, WiFi Mouse is completely free to download and use with zero in-app subscriptions or hidden fees.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Do both devices need to connect to the same network?</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <p>Yes, the client app finds the computer server over local sockets, which requires both devices to be on the same local area network (LAN).</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Does it work without active internet access?</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <p>Yes, it operates completely within your local network (intranet). Active outside internet access is not required.</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .product-page {
      display: flex;
      flex-direction: column;
      gap: 5rem;
      padding-top: 1rem;
    }

    /* Hero Section */
    .hero-split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 4rem;
      min-height: 80vh;
    }

    .hero-info {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .product-badge {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .product-title {
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 800;
      color: var(--text-primary);
      line-height: 1.1;
      letter-spacing: -0.03em;
    }

    .gradient-text {
      background: linear-gradient(135deg, #4f46e5 20%, #8b5cf6 90%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .product-description {
      font-size: 1.15rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .cta-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    /* Sandbox Mockup */
    .interactive-sandbox {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .phone-frame {
      width: 100%;
      max-width: 280px;
      background: #1f2937;
      border-radius: 36px;
      padding: 10px;
      border: 3px solid #374151;
      box-shadow: var(--shadow-xl);
    }

    .phone-notch {
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 110px;
      height: 20px;
      background: #1f2937;
      border-radius: 0 0 15px 15px;
      z-index: 10;
    }

    .phone-screen {
      background: var(--bg-surface);
      border-radius: 28px;
      overflow: hidden;
      border: 1px solid var(--border-color);
      height: 480px;
    }

    .app-ui {
      padding: 1.5rem 1rem;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .ui-header {
      text-align: center;
      margin-bottom: 0.5rem;
    }

    .status-bar {
      display: flex;
      justify-content: space-between;
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }

    .ui-header h3 {
      font-size: 1.1rem;
      color: var(--text-primary);
      margin-bottom: 0.25rem;
    }

    .connection-status {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.25rem 0.65rem;
      background: var(--success-glow);
      color: var(--success);
      border-radius: 50px;
      font-size: 0.75rem;
      font-weight: 700;
    }

    .status-dot {
      width: 6px;
      height: 6px;
      background: var(--success);
      border-radius: 50%;
      display: inline-block;
    }

    .touchpad-area {
      flex-grow: 1;
      background: var(--bg-base);
      border-radius: 14px;
      margin: 1rem 0;
      border: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .cursor-indicator {
      width: 10px;
      height: 10px;
      background: var(--primary);
      border-radius: 50%;
      position: absolute;
      box-shadow: 0 0 8px var(--primary);
    }

    @keyframes cursorTrack {
      0%, 100% { transform: translate(-30px, -20px); }
      25% { transform: translate(40px, 30px); }
      50% { transform: translate(-10px, 40px); }
      75% { transform: translate(20px, -40px); }
    }

    .animate-cursor {
      animation: cursorTrack 7s ease-in-out infinite;
    }

    .touchpad-hint {
      font-size: 0.75rem;
      color: var(--text-muted);
      z-index: 2;
    }

    .control-buttons {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }

    .control-btn {
      background: var(--primary);
      color: white;
      border: none;
      border-radius: 10px;
      padding: 0.75rem;
      font-weight: 700;
      font-size: 0.85rem;
      box-shadow: var(--shadow-sm);
      cursor: pointer;
    }

    /* Info Section & Features */
    .info-section, .setup-guide-section, .faq-section {
      padding: 3rem 0 1rem 0;
    }

    .section-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .eyebrow {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 0.75rem;
      display: block;
    }

    .section-title {
      font-size: 2.25rem;
      font-weight: 800;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }

    .section-desc {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }

    .feature-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: var(--card-radius);
      padding: 2.5rem 2rem;
      box-shadow: var(--shadow-sm);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .feature-card:hover {
      transform: translateY(-5px);
      border-color: var(--primary);
      box-shadow: var(--shadow-lg);
    }

    .feature-icon-wrapper {
      font-size: 2rem;
      margin-bottom: 1.25rem;
    }

    .feature-card h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .feature-card p {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    /* Steps guide timeline */
    .steps-timeline {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.75rem;
    }

    .steps-timeline .step-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: var(--card-radius);
      padding: 2rem;
      box-shadow: var(--shadow-sm);
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .steps-timeline .step-num {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--primary-glow);
      color: var(--primary);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 0.9rem;
    }

    .steps-timeline h4 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .steps-timeline p {
      font-size: 0.9rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* Downloads Section */
    .download-section {
      padding: 3rem 0;
    }

    .download-container-box {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: 28px;
      padding: 3rem 2rem;
      box-shadow: var(--shadow-md);
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }

    .download-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .download-card-box {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .download-card-box h3 {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .download-card-box p {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.5;
    }

    .download-btn-style {
      align-self: flex-start;
      margin-top: 0.5rem;
    }

    .server-links-group {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin-top: 0.5rem;
    }

    .server-link-pill {
      background: var(--bg-base);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 0.75rem 1.25rem;
      color: var(--text-primary);
      text-decoration: none;
      font-size: 0.95rem;
      font-weight: 600;
      transition: all 0.25s ease;
    }

    a.server-link-pill:hover {
      border-color: var(--primary);
      color: var(--primary);
      background: var(--primary-glow);
    }

    .server-link-pill.disabled {
      opacity: 0.5;
      cursor: not-allowed;
      color: var(--text-muted);
    }

    .requirements-wrapper {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      border-top: 1px solid var(--border-color);
      padding-top: 2rem;
    }

    .req-col h5 {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 0.75rem;
    }

    .req-col ul {
      list-style-type: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .req-col li {
      font-size: 0.9rem;
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .req-col li::before {
      content: "•";
      color: var(--primary);
      font-weight: bold;
    }

    /* FAQ Section */
    .faq-list {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .faq-item {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition: all 0.3s ease;
    }

    .faq-question {
      width: 100%;
      background: none;
      border: none;
      padding: 1.25rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      color: var(--text-primary);
      font-size: 1.05rem;
      font-weight: 700;
      font-family: var(--font-sans);
      text-align: left;
    }

    .faq-icon {
      color: var(--text-muted);
      transition: transform 0.3s ease;
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out;
    }

    .faq-answer p {
      padding: 0 1.5rem 1.25rem 1.5rem;
      color: var(--text-secondary);
      line-height: 1.6;
      font-size: 0.95rem;
    }

    /* Active Accordion State */
    .faq-item.active {
      border-color: var(--primary);
      box-shadow: var(--shadow-md);
    }

    .faq-item.active .faq-icon {
      transform: rotate(180deg);
      color: var(--primary);
    }

    .faq-item.active .faq-answer {
      max-height: 200px;
      transition: max-height 0.3s ease-in;
    }

    /* Responsive Design */
    @media (max-width: 1024px) {
      .hero-split {
        grid-template-columns: 1fr;
        gap: 3rem;
        text-align: center;
      }

      .hero-info {
        align-items: center;
      }

      .cta-actions {
        justify-content: center;
      }

      .download-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .requirements-wrapper {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }
  </style>

  <!-- Script for accordion toggle -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const faqItems = document.querySelectorAll('.faq-item');
      
      faqItems.forEach(item => {
        const question = item.querySelector('.faq-question');
        
        question?.addEventListener('click', () => {
          const isActive = item.classList.contains('active');
          
          // Close other items
          faqItems.forEach(otherItem => {
            if (otherItem !== item) {
              otherItem.classList.remove('active');
            }
          });
          
          // Toggle active
          if (isActive) {
            item.classList.remove('active');
          } else {
            item.classList.add('active');
          }
        });
      });
    });
  </script>
</Layout>